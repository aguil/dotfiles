{
  "$schema": "https://raw.githubusercontent.com/JanDeDobbeleer/oh-my-posh/main/themes/schema.json",
  "extends": "https://raw.githubusercontent.com/JanDeDobbeleer/oh-my-posh/main/themes/spaceship.omp.json",
  "final_space": true,
  "blocks": [
    {
      "type": "prompt",
      "alignment": "left",
      "segments": [
        {
          "type": "session",
          "style": "plain",
          "foreground": "lightYellow",
          "template": "{{ if or .SSHSession .Root }}{{ if .SSHSession }}\ueba9 {{ end }}{{ .UserName }}{{ if .Root }} (root){{ end }} {{ end }}"
        }
      ]
    }
  ]
}
