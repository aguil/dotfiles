{
  "$schema": "https://raw.githubusercontent.com/JanDeDobbeleer/oh-my-posh/main/themes/schema.json",
  "extends": "https://raw.githubusercontent.com/JanDeDobbeleer/oh-my-posh/main/themes/spaceship.omp.json",
  "final_space": true,
  "blocks": [
    {
      "type": "prompt",
      "alignment": "left",
      "segments": [
        {
          "type": "session",
          "style": "plain",
          "foreground": "lightYellow",
          "template": "{{ if or .SSHSession .Root }}{{ if .SSHSession }}\ueba9 {{ end }}{{ .UserName }}{{ if .Root }} (root){{ end }} {{ end }}"
        },
        {
          "type": "git",
          "options": {
            "disable_with_jj": true
          }
        },
        {
          "type": "jujutsu",
          "style": "plain",
          "foreground": "#cba6f7",
          "template": "<#ffffff>jj</>{{ if .ClosestBookmarks }} {{ .ClosestBookmarks }}{{ end }}{{ if .ChangeID }} \uf1fa{{ .ChangeID }}{{ end }}{{ if .Working.Changed }} {{ .Working.String }}{{ end }} ",
          "options": {
            "fetch_status": true,
            "ignore_working_copy": false
          }
        }
      ]
    }
  ]
}
