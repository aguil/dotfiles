{
  "$schema": "https://raw.githubusercontent.com/JanDeDobbeleer/oh-my-posh/main/themes/schema.json",
  "final_space": true,
  "version": 4,
  "blocks": [
    {
      "type": "prompt",
      "alignment": "left",
      "newline": true,
      "segments": [
        {
          "type": "session",
          "style": "plain",
          "foreground": "lightYellow",
          "template": "{{ if or .SSHSession .Root }}{{ if .SSHSession }}\ueba9 {{ end }}{{ .UserName }}{{ if .Root }} (root){{ end }} {{ end }}"
        },
        {
          "type": "path",
          "style": "plain",
          "foreground": "cyan",
          "template": "<#ffffff>in</> <#666666>{{ .Parent }}</>{{ .Path }} ",
          "options": {
            "style": "folder",
            "home_icon": "~",
            "folder_separator_icon": "/"
          }
        },
        {
          "type": "jujutsu",
          "style": "plain",
          "foreground": "#cba6f7",
          "template": "<#ffffff>jj</>{{ if .ClosestBookmarks }} {{ .ClosestBookmarks }}{{ end }}{{ if .ChangeID }} \uf1fa{{ .ChangeID }}{{ end }}{{ if .Working.Changed }} {{ .Working.String }}{{ end }} ",
          "options": {
            "fetch_status": true,
            "ignore_working_copy": false
          }
        },
        {
          "type": "git",
          "style": "plain",
          "foreground": "#ff94df",
          "template": "<#ffffff>on</> {{ .HEAD }}{{ if gt .StashCount 0 }} \ueb4b {{ .StashCount }}{{ end }} ",
          "options": {
            "branch_icon": " <#ff94df><b>\ue0a0 </b></>",
            "disable_with_jj": true
          }
        }
      ]
    },
    {
      "type": "prompt",
      "alignment": "left",
      "newline": true,
      "segments": [
        {
          "type": "text",
          "style": "plain",
          "foreground": "lightGreen",
          "template": "\u276f"
        }
      ]
    }
  ]
}
