# see /usr/share/doc/bash/examples/startup-files for examples.
# the files are located in the bash-doc package.

# the default umask is set in /etc/profile; for setting the umask
# for ssh logins, install and configure the libpam-umask package.
#umask 022

# if running bash
if [ -n "$BASH_VERSION" ]; then
    # include .bashrc if it exists
    if [ -f "$HOME/.bashrc" ]; then
	. "$HOME/.bashrc"
    fi
fi

# set PATH so it includes user's private bin if it exists
if [ -d "$HOME/bin" ] ; then
    PATH="$HOME/bin:$PATH"
fi

# set PATH so it includes user's private bin if it exists
if [ -d "$HOME/.local/bin" ] ; then
    PATH="$HOME/.local/bin:$PATH"
fi

if [ -n "$WSL_DISTRO_NAME" ]; then
    export SSH_AUTH_SOCK="${SSH_AUTH_SOCK:-$HOME/.ssh/agent.sock}"
    npiperelay_path="${NPIPERELAY_PATH:-}"
    win_user="${WINDOWS_USER:-}"

    if [ -z "$win_user" ] && command -v cmd.exe >/dev/null 2>&1; then
        win_user="$(cmd.exe /c "echo %USERNAME%" 2>/dev/null | tr -d '\r')"
    fi

    if [ -n "$win_user" ]; then
        win_home="/mnt/c/Users/$win_user"
    else
        win_home="/mnt/c/Users/$USER"
    fi

    if [ -z "$npiperelay_path" ]; then
        if [ -x "$win_home/bin/npiperelay.exe" ]; then
            npiperelay_path="$win_home/bin/npiperelay.exe"
        else
            for candidate in "$win_home"/AppData/Local/Microsoft/WinGet/Packages/jstarks.npiperelay*/npiperelay.exe "$win_home"/AppData/Local/Microsoft/WinGet/Packages/albertony.npiperelay*/npiperelay.exe; do
                if [ -x "$candidate" ]; then
                    npiperelay_path="$candidate"
                    break
                fi
            done
            unset candidate
        fi
    fi

    if [ -n "$npiperelay_path" ]; then
        export NPIPERELAY_PATH="$npiperelay_path"
    fi

    if [ -x "$npiperelay_path" ] && command -v socat >/dev/null 2>&1; then
        if ! ss -a 2>/dev/null | grep -Fq "$SSH_AUTH_SOCK"; then
            rm -f "$SSH_AUTH_SOCK"
            (setsid socat UNIX-LISTEN:"$SSH_AUTH_SOCK",fork EXEC:"$npiperelay_path -ei -s //./pipe/openssh-ssh-agent" >/dev/null 2>&1 &)
        fi

        relay_agent_state=$(ssh-add -l >| /dev/null 2>&1; echo $?)
        if [ "$relay_agent_state" -ne 2 ]; then
            WSL_SSH_RELAY_ACTIVE=1
        fi
        unset relay_agent_state
    fi

    unset npiperelay_path
    unset win_home
    unset win_user
fi

if [ -z "$WSL_SSH_RELAY_ACTIVE" ]; then
    # Auto-launching ssh-agent on Git for Windows
    # https://docs.github.com/en/authentication/connecting-to-github-with-ssh/working-with-ssh-key-passphrases#auto-launching-ssh-agent-on-git-for-windows
    env=~/.ssh/agent.env

    agent_load_env () { test -f "$env" && . "$env" >| /dev/null ; }

    agent_start () {
        (umask 077; ssh-agent >| "$env")
        . "$env" >| /dev/null ; }

    agent_load_env

    # agent_run_state: 0=agent running w/ key; 1=agent w/o key; 2=agent not running
    agent_run_state=$(ssh-add -l >| /dev/null 2>&1; echo $?)

    if [ ! "$SSH_AUTH_SOCK" ] || [ $agent_run_state = 2 ]; then
        agent_start
        ssh-add
    elif [ "$SSH_AUTH_SOCK" ] && [ $agent_run_state = 1 ]; then
        ssh-add
    fi

    unset env
fi

unset WSL_SSH_RELAY_ACTIVE


. "$HOME/.local/bin/env"
