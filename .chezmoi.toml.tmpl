[data.tooling.work]
  editors = ["intellij-idea", "cursor"]

[data.tooling.personal]
  editors = ["opencode", "vscode"]

{{- if eq .chezmoi.os "windows" }}
[cd]
  command = "powershell"
  args = ["-NoLogo", "-NoExit"]

[interpreters.sh]
